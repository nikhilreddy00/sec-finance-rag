# Required — get your free API key at console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Optional — Cohere reranking (free tier: 1,000 calls/month)
# Sign up at dashboard.cohere.com
# Without this, falls back to cosine similarity reranking (still works great)
COHERE_API_KEY=your-cohere-key-here

# Vector store backend: "chroma" (default, local) or "qdrant" (cloud)
VECTOR_STORE=chroma

# Claude model — claude-sonnet-4-6 is the default
CLAUDE_MODEL=claude-sonnet-4-6

# Logging level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=WARNING
